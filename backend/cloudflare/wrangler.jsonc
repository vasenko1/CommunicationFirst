{
  "$schema": "../../node_modules/wrangler/config-schema.json",

  "name": "communication-first",

  "main": "src/worker.js",

  "compatibility_date": "2026-07-17",

  "observability": {
    "enabled": true
  },

  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "Room"
      }
    ]
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "Room"
      ]
    }
  ]
}
